{
  "name": "crechebooks",
  "version": "1.0.0",
  "description": "AI-powered bookkeeping system for South African creches and pre-schools",
  "author": "CrecheBooks Development Team",
  "private": true,
  "license": "PROPRIETARY",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @crechebooks/api start:dev",
    "dev:web": "pnpm --filter @crechebooks/web dev",
    "start": "pnpm -r --parallel start",
    "start:api": "pnpm --filter @crechebooks/api start:prod",
    "start:web": "pnpm --filter @crechebooks/web start",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "test": "pnpm -r test",
    "test:api": "pnpm --filter @crechebooks/api test",
    "test:web": "pnpm --filter @crechebooks/web test",
    "test:e2e": "pnpm --filter @crechebooks/api test:e2e",
    "test:cov": "pnpm -r test:cov",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "prisma:generate": "pnpm --filter @crechebooks/api prisma:generate",
    "prisma:migrate": "pnpm --filter @crechebooks/api prisma:migrate",
    "prisma:push": "pnpm --filter @crechebooks/api prisma:push",
    "prisma:studio": "pnpm --filter @crechebooks/api prisma:studio",
    "clean": "pnpm -r exec rm -rf node_modules dist .next coverage",
    "clean:install": "pnpm clean && pnpm install",
    "docker:build": "./scripts/docker-build.sh all",
    "docker:build:api": "./scripts/docker-build.sh api",
    "docker:build:web": "./scripts/docker-build.sh web",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "dev:start": "./scripts/dev-start.sh",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "dev:infra:reset": "docker compose -f docker-compose.dev.yml down -v && docker compose -f docker-compose.dev.yml up -d",
    "deploy": "./scripts/deploy-railway.sh",
    "cli": "pnpm --filter @crechebooks/cli start",
    "cli:dev": "pnpm --filter @crechebooks/cli dev",
    "cli:build": "pnpm --filter @crechebooks/cli build"
  },
  "devDependencies": {
    "@claude-flow/embeddings": "3.0.0-alpha.7",
    "better-sqlite3": "^12.6.2",
    "claude-flow": "3.1.0-alpha.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1",
    "@types/node": "^22.10.7",
    "@types/pdfkit": "^0.17.4",
    "exceljs": "^4.4.0",
    "form-data": "^4.0.5",
    "mailgun.js": "^12.6.1",
    "pdfkit": "^0.17.2"
  },
  "pnpm": {
    "overrides": {
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "qs": ">=6.14.2",
      "hono": "^4.12.25",
      "tar": "^7.5.16",
      "next": "^15.5.18",
      "fast-xml-parser": ">=5.3.4",
      "handlebars": "^4.7.9",
      "protobufjs": "^7.5.6",
      "axios": "^1.16.0",
      "form-data": "^4.0.6",
      "undici": "^7.28.0",
      "path-to-regexp": "^8.4.0",
      "tmp": "^0.2.6",
      "serialize-javascript": "^7.0.5",
      "fast-uri": "^3.1.2",
      "flatted": "^3.4.2",
      "ws": "^8.21.0",
      "http-proxy-middleware": "^3.0.7",
      "socket.io-parser": "^4.2.6",
      "rollup": "^4.59.0",
      "defu": "^6.1.5",
      "effect": "^3.20.0",
      "koa": "^3.1.2",
      "multer": "^2.2.0",
      "vite": "^7.3.5",
      "@babel/core": "^7.29.6",
      "@tootallnate/once": "^2.0.1",
      "follow-redirects": "^1.16.0",
      "webpack": "^5.104.1",
      "@nestjs/core": "^11.1.18",
      "postcss": "^8.5.10",
      "@hono/node-server": "^1.19.13",
      "fast-xml-builder": "^1.1.6",
      "turbo": "^2.9.14",
      "lodash": "^4.18.0",
      "@opentelemetry/core": "^2.8.0",
      "picomatch": "^4.0.4"
    }
  }
}
